/**
 * Prisma Schema — AvisaTech Task Management Application
 *
 * ## Enum Choices
 * - `TaskStatus` (TODO | IN_PROGRESS | DONE): Maps directly to the three-state workflow
 *   described in the spec. Using a DB-level enum ensures data integrity without needing
 *   application-level checks on reads.
 * - `TaskPriority` (LOW | MEDIUM | HIGH): Three-tier priority gives enough granularity
 *   for triage without over-complicating the UI dropdown. MEDIUM is the default to avoid
 *   every new task appearing as urgent.
 *
 * ## Indexing Decisions
 * - `status`: Indexed because the primary list view filters by status (e.g., "show me
 *   all IN_PROGRESS tasks"). Without this index, every filter query would full-table-scan.
 * - `dueDate`: Indexed because sorting by due date is a supported query param. Also enables
 *   efficient range queries for "overdue" calculations.
 * - `createdAt`: Not separately indexed because PostgreSQL already stores rows roughly in
 *   insertion order, and the primary key (UUID) provides sufficient uniqueness. If the table
 *   grows beyond ~100k rows, adding an index here would be worth revisiting.
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Represents the current workflow state of a task.
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

/// Represents the urgency level of a task.
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

/// A single unit of work in the task management system.
model Task {
  id          String       @id @default(uuid()) @db.Uuid
  title       String       @db.VarChar(200)
  description String?      @db.VarChar(2000)
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @db.Timestamptz()
  createdAt   DateTime     @default(now()) @db.Timestamptz()
  updatedAt   DateTime     @updatedAt @db.Timestamptz()

  // Indexes for the most common query patterns: filter-by-status and sort-by-dueDate.
  @@index([status])
  @@index([dueDate])
}
