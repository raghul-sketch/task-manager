# Database connection string for Prisma.
# Adjust credentials and host if not using the provided docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/taskmanager?schema=public"

# Port the Express server listens on.
PORT=3001

# Allowed origin for CORS — should match the Vite dev server URL.
FRONTEND_ORIGIN="http://localhost:5173"
